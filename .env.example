# ============================================================
# SuperSiesta — Root .env
# Variables consumed by docker-compose.yml
# Copy this to .env and customise before running docker compose
# ============================================================

# ---- Ports exposed on your host machine ----
FRONT_PORT=80
API_PORT=8000
DB_EXPOSE_PORT=3306

# ---- MySQL ----
DB_ROOT_PASSWORD=SuperSiesta_Root_2024!
DB_DATABASE=SuperSiestaDB
DB_USERNAME=siesta_user
DB_PASSWORD=SuperSiesta_Pass_2024!

# ---- Frontend build-time variable ----
# Must be a URL accessible FROM THE BROWSER (not inside Docker network)
VITE_API_URL=http://localhost:8000/api
